# Server Configuration
PORT=8888
NODE_ENV=development

# Admin Bootstrap (optional — only needed for initial admin creation)
# ADMIN_PASSWORD_HASH must be a SHA-256 hex string of the admin password.
# Example: echo -n "your_password" | sha256sum
# Leave both empty to skip admin bootstrap (safe default).
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
ADMIN_NAME=Administrator

# Groq AI Configuration
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/analyze",    "destination": "/api/core" },
    { "source": "/api/chart",      "destination": "/api/core" },
    { "source": "/api/elements",   "destination": "/api/core" },
    { "source": "/api/scores",     "destination": "/api/core" },
    { "source": "/api/pillars",    "destination": "/api/core" },
    { "source": "/api/analysis",   "destination": "/api/core" },
    { "source": "/api/advanced",   "destination": "/api/core" },
    { "source": "/api/basic-info", "destination": "/api/core" },
    { "source": "/api/consultant/themes",    "destination": "/api/consultant" },
    { "source": "/api/consultant/questions", "destination": "/api/consultant" },
    { "source": "/api/consultant/ask",       "destination": "/api/consultant" },
    { "source": "/api/stars",         "destination": "/api/misc" },
    { "source": "/api/luck-cycles",   "destination": "/api/misc" },
    { "source": "/api/year-analysis", "destination": "/api/misc" },
    { "source": "/api/analyze-time",  "destination": "/api/misc" },
    { "source": "/api/select-dates",  "destination": "/api/misc" },
    { "source": "/api/classic-texts", "destination": "/api/misc" },
    { "source": "/api/luan-giai",     "destination": "/api/misc" },
    { "source": "/api/dayun",         "destination": "/api/misc" },
    { "source": "/api/auth/me",       "destination": "/api/misc" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-user-id" }
      ]
    }
  ]
}
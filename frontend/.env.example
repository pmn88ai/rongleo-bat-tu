# Site URL (used for sitemap, canonical, OpenGraph)
VITE_SITE_URL=https://rongleo-menhly.vercel.app

# Google Analytics 4 Measurement ID (leave empty to disable GA)
# Format: G-XXXXXXXXXX
VITE_GA_ID=

# Google Search Console Verification Token
# Copy from Search Console > Settings > Ownership Verification > HTML tag
# Format: google-site-verification token string
VITE_GOOGLE_SITE_VERIFICATION=
